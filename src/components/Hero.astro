---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import OpeningStatus from "@components/OpeningStatus.astro";
import { address } from "@/lib/opening-hours";
import interiorLounge from "@/assets/restaurant/interior-lounge-hero.webp";
---

<section
  class="relative isolate flex min-h-[calc(100svh-5rem)] items-center overflow-hidden sm:min-h-[calc(100svh-6rem)]"
>
  <Image
    src={interiorLounge}
    alt="Gemütlicher Sitzbereich im Café Det Lille Hus"
    widths={[800, 1200, 1800, 2400]}
    sizes="100vw"
    class="absolute inset-0 h-full w-full object-cover object-[52%_center] brightness-[1.02] saturate-[0.98] sm:object-center"
    loading="eager"
    fetchpriority="high"
  />
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-gradient-to-r from-dark/35 via-dark/5 to-transparent"
  ></div>
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-gradient-to-t from-dark/10 via-transparent to-transparent"
  ></div>

  <div class="relative mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 sm:py-16 lg:py-20">
    <div
      data-reveal
      class="max-w-[34rem] rounded-3xl border border-dark-foreground/10 bg-dark/80 p-6 shadow-2xl shadow-dark/40 backdrop-blur-[6px] sm:p-9 lg:p-10"
    >
      <div class="flex items-center gap-3">
        <span aria-hidden="true" class="h-px w-8 shrink-0 bg-tan"></span>
        <p class="text-xs font-semibold tracking-[0.2em] text-tan uppercase sm:text-sm">
          Café &amp; Wohnaccessoires
        </p>
      </div>

      <h1
        class="mt-4 text-balance font-display text-[2.5rem] leading-[1.05] font-semibold text-dark-foreground sm:text-5xl"
      >
        Ein kleines Haus für gute Momente.
      </h1>
      <p class="mt-5 max-w-md text-base leading-relaxed text-dark-foreground/85 sm:text-lg">
        Handgebrühter Kaffee, hausgemachter Kuchen und eine ruhige, warme Atmosphäre – mitten in
        Habichtswald-Ehlen.
      </p>

      <div
        class="mt-7 grid gap-2 border-t border-dark-foreground/15 pt-5 sm:grid-cols-[minmax(0,1fr)_minmax(0,1.2fr)] sm:items-center sm:gap-5"
      >
        <a
          href={`https://www.google.com/maps?q=${encodeURIComponent(`${address.street}, ${address.zipCity}`)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex min-h-11 items-center gap-2 text-sm leading-snug font-medium text-dark-foreground/85 transition hover:text-tan"
        >
          <Icon name="mdi:map-marker" class="h-4 w-4 shrink-0 text-tan" />
          <span class="underline decoration-transparent underline-offset-4 transition group-hover:decoration-tan/60">
            {address.street}, {address.zipCity}
          </span>
        </a>
        <div class="sm:border-l sm:border-dark-foreground/15 sm:pl-5">
          <OpeningStatus />
        </div>
      </div>
    </div>
  </div>
</section>
