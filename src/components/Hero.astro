---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import OpeningStatus from "@components/OpeningStatus.astro";
import { address } from "@/lib/opening-hours";
import interiorLounge from "@/assets/restaurant/interior-lounge.jpg";
---

<section class="relative isolate flex min-h-[92vh] items-center overflow-hidden">
  <Image
    src={interiorLounge}
    alt="Gemütlicher Sitzbereich im Café Det Lille Hus"
    widths={[800, 1200, 1800, 2400]}
    sizes="100vw"
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-dark/85 via-dark/40 to-transparent"></div>

  <div class="relative mx-auto w-full max-w-6xl px-4 py-24 sm:px-6">
    <div data-reveal class="max-w-lg rounded-2xl bg-dark/70 p-8 backdrop-blur-sm sm:p-10">
      <p class="text-sm font-bold tracking-[0.25em] text-tan uppercase">Café &amp; Wohnaccessoires</p>
      <h1 class="mt-4 text-balance font-display text-4xl leading-[1.05] font-extrabold text-dark-foreground sm:text-5xl">
        Ein kleines Haus für gute Momente.
      </h1>
      <p class="mt-5 max-w-md text-lg leading-relaxed text-dark-foreground/80">
        Handgebrühter Kaffee, hausgemachter Kuchen und eine ruhige, warme Atmosphäre – mitten in
        Habichtswald-Ehlen.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a
          href="#speisekarte"
          class="inline-flex items-center gap-2 rounded-full bg-tan px-6 py-3 text-sm font-bold tracking-wide text-tan-foreground uppercase transition hover:brightness-110"
        >
          Speisekarte
        </a>
        <a
          href="#kontakt"
          class="inline-flex items-center gap-2 rounded-full border border-dark-foreground/40 px-6 py-3 text-sm font-bold tracking-wide text-dark-foreground uppercase transition hover:border-dark-foreground hover:bg-dark-foreground/10"
        >
          Anfahrt &amp; Kontakt
        </a>
      </div>

      <div class="mt-8 flex flex-col gap-3 border-t border-dark-foreground/20 pt-6 sm:flex-row sm:items-center sm:gap-6">
        <a
          href={`https://www.google.com/maps?q=${encodeURIComponent(`${address.street}, ${address.zipCity}`)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-dark-foreground transition hover:text-tan"
        >
          <Icon name="mdi:map-marker" class="h-4 w-4 text-tan" />
          {address.street}, {address.zipCity}
        </a>
        <OpeningStatus />
      </div>
    </div>
  </div>
</section>
