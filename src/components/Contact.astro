---
import { Icon } from "astro-icon/components";
import MapEmbed from "@components/MapEmbed.astro";
import { address, openingHours } from "@/lib/opening-hours";

const today = new Date().getDay();
---

<section id="kontakt" class="border-t border-border bg-muted/40">
  <div class="mx-auto grid max-w-6xl gap-12 px-4 py-20 sm:px-6 sm:py-28 lg:grid-cols-2 lg:gap-16">
    <div>
      <p class="text-sm font-medium tracking-[0.2em] text-secondary uppercase">Besuch uns</p>
      <h2 class="mt-3 font-display text-3xl font-normal text-foreground sm:text-4xl">
        Anfahrt &amp; Öffnungszeiten
      </h2>

      <dl class="mt-8 space-y-5 text-foreground">
        <div class="flex items-start gap-3">
          <Icon name="mdi:map-marker-outline" class="mt-0.5 h-5 w-5 shrink-0 text-primary" />
          <div>
            <dt class="sr-only">Adresse</dt>
            <dd>{address.street}<br />{address.zipCity}</dd>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <Icon name="mdi:phone-outline" class="mt-0.5 h-5 w-5 shrink-0 text-primary" />
          <div>
            <dt class="sr-only">Telefon</dt>
            <dd><a href={`tel:${address.phone.replace(/\s+/g, "")}`} class="hover:text-primary">{address.phone}</a></dd>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <Icon name="mdi:email-outline" class="mt-0.5 h-5 w-5 shrink-0 text-primary" />
          <div>
            <dt class="sr-only">E-Mail</dt>
            <dd><a href={`mailto:${address.email}`} class="hover:text-primary">{address.email}</a></dd>
          </div>
        </div>
      </dl>

      <table class="mt-8 w-full max-w-sm border-collapse text-sm">
        <caption class="sr-only">Öffnungszeiten</caption>
        <tbody>
          {
            openingHours.map((day) => (
              <tr
                class={`border-b border-border/70 ${day.day === today ? "text-foreground font-medium" : "text-muted-foreground"}`}
              >
                <th scope="row" class="py-2 pr-4 text-left font-normal">
                  {day.label}
                </th>
                <td class="py-2 text-right">
                  {day.closed ? "Ruhetag" : `${day.open} – ${day.close} Uhr`}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <MapEmbed mapsQuery={`${address.street}, ${address.zipCity}`} />
  </div>
</section>
