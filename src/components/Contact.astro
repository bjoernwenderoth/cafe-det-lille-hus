---
import { Icon } from "astro-icon/components";
import MapEmbed from "@components/MapEmbed.astro";
import { address, openingHours } from "@/lib/opening-hours";

const today = new Date().getDay();
---

<section id="kontakt" class="bg-dark py-20 sm:py-28">
  <div class="mx-auto grid max-w-6xl gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:gap-16">
    <div data-reveal>
      <p class="text-sm font-semibold tracking-[0.25em] text-tan uppercase">Besuch uns</p>
      <h2 class="mt-3 text-balance font-display text-3xl font-semibold text-dark-foreground sm:text-4xl">
        Anfahrt &amp; Öffnungszeiten
      </h2>

      <dl class="mt-8 space-y-5 text-dark-foreground">
        <div class="flex items-start gap-3">
          <Icon name="mdi:map-marker-outline" class="mt-0.5 h-5 w-5 shrink-0 text-tan" />
          <div>
            <dt class="sr-only">Adresse</dt>
            <dd>{address.street}<br />{address.zipCity}</dd>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <Icon name="mdi:phone-outline" class="mt-0.5 h-5 w-5 shrink-0 text-tan" />
          <div>
            <dt class="sr-only">Telefon</dt>
            <dd>
              <a href={`tel:${address.phone.replace(/\s+/g, "")}`} class="hover:text-tan">{address.phone}</a>
            </dd>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <Icon name="mdi:facebook" class="mt-0.5 h-5 w-5 shrink-0 text-tan" />
          <div>
            <dt class="sr-only">Facebook</dt>
            <dd>
              <a
                href="https://www.facebook.com/DetLilleHusEhlen"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-tan"
              >
                Det Lille Hus auf Facebook
              </a>
            </dd>
          </div>
        </div>
      </dl>

      <table class="mt-8 w-full max-w-sm border-collapse text-sm">
        <caption class="sr-only">Öffnungszeiten</caption>
        <tbody>
          {
            openingHours.map((day) => (
              <tr
                class={`border-b border-dark-foreground/15 ${day.day === today ? "font-semibold text-dark-foreground" : "text-dark-foreground/60"}`}
              >
                <th scope="row" class="py-2 pr-4 text-left font-normal">
                  {day.label}
                </th>
                <td class="py-2 text-right">{day.closed ? "Ruhetag" : `${day.open} – ${day.close} Uhr`}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div data-reveal>
      <MapEmbed mapsQuery={`${address.street}, ${address.zipCity}`} dark />
    </div>
  </div>
</section>
