---
import { Image } from "astro:assets";
import interiorShopCorner from "@/assets/restaurant/interior-shop-corner.webp";
import wafflesTerrace from "@/assets/restaurant/waffles-terrace.webp";
import hotChocolate from "@/assets/restaurant/hot-chocolate.webp";
import wafflesAutumn from "@/assets/restaurant/waffles-autumn.webp";
import breakfastPlatter from "@/assets/restaurant/breakfast-platter.webp";
import interiorLounge from "@/assets/restaurant/interior-lounge.jpg";

const photos = [
  { src: interiorShopCorner, alt: "Gemütliche Sitzecke im Café Det Lille Hus" },
  { src: wafflesTerrace, alt: "Frisch gebackene Waffeln mit Kaffee auf der Terrasse" },
  { src: hotChocolate, alt: "Heiße Schokolade im Café Det Lille Hus" },
  { src: interiorLounge, alt: "Sitzbereich im Café Det Lille Hus" },
  { src: wafflesAutumn, alt: "Waffeln mit Cappuccino und herbstlicher Deko" },
  { src: breakfastPlatter, alt: "Frühstücksteller mit Käse, Schinken und Obst" },
];
---

<section class="bg-background pt-20 sm:pt-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <p data-reveal class="text-center text-sm font-bold tracking-[0.25em] text-secondary uppercase">Impressionen</p>
    <h2 data-reveal class="mt-3 text-balance text-center font-display text-3xl font-extrabold text-foreground sm:text-4xl">
      Ein Blick ins Det Lille Hus
    </h2>
  </div>

  <div class="mt-12 grid grid-cols-2 sm:grid-cols-3">
    {
      photos.map((photo, i) => (
        <Image
          src={photo.src}
          alt={photo.alt}
          widths={[300, 500, 700]}
          sizes="(min-width: 640px) 33vw, 50vw"
          data-reveal
          style={`transition-delay: ${(i % 3) * 90}ms`}
          class="aspect-square h-full w-full object-cover"
        />
      ))
    }
  </div>
</section>
