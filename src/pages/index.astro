---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import Story from "@components/Story.astro";
import Pillars from "@components/Pillars.astro";
import MenuCategories from "@components/MenuCategories.astro";
import Gallery from "@components/Gallery.astro";
import Contact from "@components/Contact.astro";
import MenuTabs from "@/components/MenuTabs";
import { localize, pbFileUrl } from "@/lib/pocketbase";

const categories = await getCollection("categories");
const products = await getCollection("products");

const currency = new Intl.NumberFormat("de-DE", { style: "currency", currency: "EUR" });

const sortedCategories = categories.sort((a, b) => a.data.position - b.data.position);

const menu = sortedCategories
  .map((category) => ({
    id: category.id,
    label: localize(category.data.name),
    items: products
      .filter((product) => product.data.category === category.id && product.data.available)
      .sort((a, b) => a.data.position - b.data.position)
      .map((product) => ({
        name: localize(product.data.name),
        description: localize(product.data.description) || undefined,
        price: currency.format(product.data.price),
        image: product.data.image
          ? pbFileUrl(product.data.collectionId, product.id, product.data.image, "400x300")
          : undefined,
        alt: localize(product.data.alt) || undefined,
      })),
  }))
  .filter((category) => category.items.length > 0);

const categoryTiles = menu.map((c) => ({ id: c.id, label: c.label }));
---

<BaseLayout
  title="Startseite"
  description="Café Det Lille Hus – Handgebrühter Kaffee, hausgemachter Kuchen und eine warme, ruhige Atmosphäre mitten in Habichtswald-Ehlen."
>
  <Hero />

  <Story />

  <Pillars />

  <MenuCategories categories={categoryTiles} />

  <section id="speisekarte" class="scroll-mt-16 bg-tan py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p data-reveal class="text-center text-sm font-bold tracking-[0.25em] text-tan-foreground/80 uppercase">
        Speisekarte
      </p>
      <h2 data-reveal class="mt-3 text-balance text-center font-display text-3xl font-extrabold text-tan-foreground sm:text-4xl">
        Was uns freut, dir zu servieren
      </h2>
      <p data-reveal class="mx-auto mt-4 max-w-xl text-center text-tan-foreground/80">
        Eine kleine Auswahl unserer Karte – wechselt saisonal und je nach Tagesangebot.
      </p>

      <div class="mt-12">
        <MenuTabs client:idle menu={menu} />
      </div>
    </div>
  </section>

  <Gallery />

  <Contact />
</BaseLayout>
