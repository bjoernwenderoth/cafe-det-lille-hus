---
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import exteriorFacade from "@/assets/restaurant/exterior-facade.jpg";
---

<BaseLayout
  title="Über uns"
  description="Erfahre mehr über die Geschichte und Philosophie von Café Det Lille Hus."
>
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-24">
    <p data-reveal class="text-sm font-bold tracking-[0.25em] text-secondary uppercase">Unsere Geschichte</p>
    <h1 data-reveal class="mt-3 font-display text-4xl font-extrabold text-foreground sm:text-5xl">Über uns</h1>

    <Image
      data-reveal
      src={exteriorFacade}
      alt="Das Fachwerkhaus von Café Det Lille Hus in Habichtswald-Ehlen"
      widths={[500, 700, 900]}
      sizes="(min-width: 768px) 48rem, 90vw"
      class="arch-top mt-8 h-80 w-full object-cover sm:h-[26rem]"
    />

    <p data-reveal class="mt-8 text-lg leading-relaxed text-muted-foreground">
      Café Det Lille Hus wurde mit der Idee gegründet, einen Ort zu schaffen, an dem sich
      Menschen wohlfühlen – bei einer guten Tasse Kaffee, einem Stück hausgemachtem Kuchen und
      angenehmer Gesellschaft.
    </p>
    <p data-reveal class="mt-4 text-lg leading-relaxed text-muted-foreground">
      Der Name "Det Lille Hus" bedeutet "das kleine Haus" und steht für unsere Philosophie: ein
      gemütlicher, familiärer Rückzugsort mitten im Alltag.
    </p>
    <p data-reveal class="mt-4 text-lg leading-relaxed text-muted-foreground">
      Wir legen großen Wert auf regionale Zutaten, handwerkliche Zubereitung und einen
      herzlichen, persönlichen Service.
    </p>
  </section>
</BaseLayout>
